# 注意: devbox の activate (`eval "$(devbox generate direnv --print-envrc)"`) は
# 各 repo の root .envrc 側で行うこと。 vendor/flame/.envrc から呼ぶと devbox の
# PWD が `vendor/flame/` になり、 root devbox.json (vendor/flame/devbox.json の copy)
# 内の init_hook 相対パス `vendor/flame/devbox/init.sh` が解決できず壊れる。

# flame ツール本体は private repository 配下に置かれる場合があり、 そのとき Go module
# (= flame の lib module 等) を fetch するために GOPRIVATE で proxy / sumdb を bypass
# する必要がある。 source 提供元 (= `flame.yaml.harness.source` の `github.com/<owner>/<repo>`)
# から動的に GOPRIVATE 範囲を組み立て、 source 提供元の owner namespace 全体を private
# 扱いにする。 fork / mirror 配信先 (= owner が異なる) でも同じ仕組みが機能する。
flame_source_line=$(awk '/^[[:space:]]+source:/ { print $2; exit }' "$(git rev-parse --show-toplevel 2>/dev/null)/flame.yaml" 2>/dev/null || true)
case "$flame_source_line" in
  github.com/*)
    flame_source_owner="${flame_source_line#github.com/}"
    flame_source_owner="${flame_source_owner%%/*}"
    export GOPRIVATE="github.com/${flame_source_owner}/*"
    ;;
esac
unset flame_source_line flame_source_owner
