tmp
.devbox
.direnv
.local
.claude/.cache/
.claude/scheduled_tasks.lock

# Go workspace は flame self では採用しない (FLI_APP_0001 §1)。 偶発的な
# `git add` を防ぐ untracked 段階の防衛層。
go.work
go.work.sum

# flame harness は vendor/flame/ 配下を SoT として追跡する (FLM_FEA_0003)。
# 親 dir 全体を ignore すると Git が下に降りないため、 *  で直接子のみを
# ignore してから !vendor/flame で flame だけ unignore する。
vendor/*
!vendor/flame
